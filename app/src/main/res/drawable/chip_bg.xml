<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/focus_fill"/>
            <stroke android:width="2dp" android:color="@color/focus_stroke"/>
            <corners android:radius="12dp"/>
            <padding android:left="16dp" android:right="16dp" android:top="10dp" android:bottom="10dp"/>
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#2663D4E2"/>
            <stroke android:width="1dp" android:color="#8063D4E2"/>
            <corners android:radius="12dp"/>
            <padding android:left="16dp" android:right="16dp" android:top="10dp" android:bottom="10dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/card_bg"/>
            <stroke android:width="1dp" android:color="@color/hairline"/>
            <corners android:radius="12dp"/>
            <padding android:left="16dp" android:right="16dp" android:top="10dp" android:bottom="10dp"/>
        </shape>
    </item>
</selector>
