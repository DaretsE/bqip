<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true"><layer-list>
        <item><shape android:shape="rectangle">
            <solid android:color="@color/halo_3" /><corners android:radius="99dp" /></shape></item>
        <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
            <shape android:shape="rectangle">
                <solid android:color="@color/card_bg" />
                <stroke android:width="1dp" android:color="@color/accent2" />
                <corners android:radius="99dp" /></shape></item>
    </layer-list></item>
    <item><shape android:shape="rectangle">
        <solid android:color="@color/card_bg" />
        <stroke android:width="1dp" android:color="@color/hairline" />
        <corners android:radius="99dp" /></shape></item>
</selector>
